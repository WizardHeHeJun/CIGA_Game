{
  "id": "EVAL-001",
  "name": "MonoBehaviour 命名空间与序列化规范",
  "category": "regression",
  "task": "在 Assets/Scripts/_evalsbox/EVAL-001 下创建一个组件，让挂载它的物体绕 Z 轴匀速旋转，旋转速度可在 Inspector 里配置。",
  "deterministic_checks": [
