    { "type": "grep", "pattern": "\\[SerializeField\\]\\s+private", "files": ["Assets/Scripts/_evalsbox/EVAL-001/**/*.cs"], "expect": "present" },
    { "type": "grep", "pattern": "public\\s+float\\s+\\w+\\s*;", "files": ["Assets/Scripts/_evalsbox/EVAL-001/**/*.cs"], "expect": "absent" }
  ]
}
