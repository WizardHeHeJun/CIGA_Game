[
  {
    "id": "public-mutable-field",
    "scope": "line",
    "file_context": ":\\s*MonoBehaviour\\b",
    "pattern": "^\\s*public\\s+[A-Za-z_][\\w<>\\[\\]\\.,\\s]*?\\s+[A-Za-z_]\\w*\\s*(=[^;]*)?;\\s*$",
    "exclude_patterns": [
      "\\bconst\\b",
      "\\breadonly\\b",
      "\\bstatic\\b",
      "\\bevent\\b",
      "\\bdelegate\\b",
      "=>",
      "\\(",
      "\\{"
    ],
    "severity": "block",
    "rule": "字段与序列化",
    "violation_tpl": "MonoBehaviour 用 public 可变字段暴露 Inspector: {line}",
    "fix": "改为 [SerializeField] private，或公开只读属性 public T X { get; private set; }",
    "ref": "csharp-code #字段与序列化"
  },
  {
    "id": "missing-namespace",
    "scope": "file",
    "file_context": "\\b(class|struct|enum|interface)\\s+\\w",
    "file_context_absent": "\\bnamespace\\s+\\w",
    "exclude_patterns": [],
    "severity": "block",
    "rule": "命名空间",
    "violation_tpl": "文件缺少 namespace（业务类型必须在 Ciga.* 命名空间内）",
    "fix": "用 namespace Ciga.<模块> { ... } 包裹类型",
    "ref": "csharp-code #命名"
  },
  {
    "id": "legacy-ui-text",
    "scope": "line",
    "pattern": "UnityEngine\\.UI\\.Text\\b",
    "exclude_patterns": ["//"],
    "severity": "warn",
    "rule": "UI 文本",
    "violation_tpl": "使用了旧版 UnityEngine.UI.Text: {line}",
    "fix": "改用 TextMeshPro（TMP_Text / TextMeshProUGUI）",
    "ref": "unity-2d-urp #UI"
  },
  {
    "id": "find-object",
    "scope": "line",
    "pattern": "\\b(FindObjectOfType|GameObject\\.Find)\\b",
    "exclude_patterns": ["//", "/\\*"],
    "severity": "warn",
    "rule": "引用获取",
    "violation_tpl": "使用了 FindObjectOfType / GameObject.Find（慢且脆）: {line}",
    "fix": "用 [SerializeField] 引用或在 Awake/Start 缓存；必须查找时仅初始化期用一次",
    "ref": "unity-mono #引用获取"
  }
]
